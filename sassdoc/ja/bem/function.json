            ""
        ]
    },
    "bem--generate-mod-list": {
        "description": [
            "要素に対する修飾子のリストを生成します。",
            ""
        ]
    },
    "bem--generate-elem-selector": {
        "description": [
            "BEM 要素に適したセレクターを生成します。",
            ""
        ],
        "parameters": {
            "block": {
                "description": [
                    "ブロック名。"
                ]
            },
            "elem": {
                "description": [
                    "要素名。"
                ]
            },
            "mod": {
                "description": [
                    "オプションの修飾子。"
                ]
            },
            "first": {
                "description": [
                    "(オプション) ネスト用の最初のセレクター。"
                ]
            }
        },
        "returns": {
            "description": [
                "生成されたセレクター。"
            ]
        }
    },
    "bem-selector": {
        "description": [
            "完全 BEM セレクターを生成します。",
            ""
        ],
        "parameters": {
            "block": {
                "description": [
                    "文字列ブロックの名前。必須。"
                ]
            },
            "elem": {
                "description": [
                    "サブ要素の名前。`$mod` が存在しない場合は、",
                    "$block と結合されます。$mod が存在する場合、それは `$block--$mod` の下にネストされます。"
                ]
            },
            "mod": {
                "description": [
                    "ブロック修飾。"
                ]
            },
            "mods": {
                "description": [
                    "ブロック修飾のリスト。",
                    ""
                ]
            }
        },
        "returns": {
            "description": [
                "生成された BEM セレクター文字列。"
            ]
        },
        "example": [
            {
                "description": [
                    "ブロックを含みます。"
                ],
                "code": [
                    "$selector: bem-selector(block); // returns .block"
                ]
            },
            {
                "description": [
                    "要素とブロックを含みます。"
                ],
                "code": [
                    "$selector: bem-selector(block, $elem: elem); // returns .block__elem"
                ]
            },
            {
                "description": [
                    "ブロック、要素と要素修飾を含みます。"
                ],
                "code": [
                    "$selector: bem-selector(block, $elem: (elem, mod); // returns .block__elem--mod"
                ]
            },
            {
                "description": [
                    "ブロックとブロック修飾を含みます。"
                ],
                "code": [
                    "$selector: bem-selector(block, $mod: mod) // returns .block--mod"
                ]
            },
            {
                "description": [
                    "ブロックおよび複数のブロック修飾子を含みます。"
                ],
                "code": [
                    "$selector: bem-selector(block, $mods: (mod-1, mod-2)) // returns .block--mod-1.block--mod-2"
                ]
            },
            {
                "description": [
                    "ブロック修飾を続くブロック サブ要素を含みます。"
                ],
                "code": [
                    "$selector: bem-selector(block, $m: mod, $e: elem); // returns .block--mod .block__elem"
                ]
            }
        ]
    },
    "elem": {
        "description": [
            "BEM 要素セレクター文字列を返します。修飾子が指定されている場合は、要素セレクターに追加されます。",
            ""
        ],
        "parameters": {
            "block": {
                "description": [
                    "ブロックの名前。"
                ]
            },
            "elem": {
                "description": [
                    "要素の名前。"
                ]
            },
            "mod": {
                "description": [
                    "修飾の名前。オプション。"
                ]
            }
        },
        "returns": {
            "description": [
                "BEM 要素セレクター文字列。"
            ]
        },
        "example": [
            {
                "code": [
                    "$selector: elem('button', 'icon') // returns '.button__icon'",
                    "$selector: elem('button', 'icon', 'big') // returns '.button__icon--big'"
                ]
            }
        ]
    },
    "mod": {
        "description": [
            "ブロックの BEM 修飾子セレクター文字列を返します。",
            ""
        ],
        "parameters": {
            "block": {
                "description": [
                    "ブロックの名前。"
                ]
            },
            "mod": {
                "description": [
                    "修飾の名前。"
                ]
            }
        },
        "returns": {
            "description": [
                "BEM 修飾子セレクター文字列。"
            ]
        },
        "example": [
            {
                "code": [
                    "$selector: mod('button', 'primary') // returns '.button--primary'",
                    "$selector: mod('card', 'outlined') // returns '.card--outlined'"
                ]
            }
        ]
    }
}