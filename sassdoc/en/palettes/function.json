{
    "palette": {
        "description": [
            "<p>Generates a color palette.</p>",
            ""
        ],
        "parameters": {
            "primary": {
                "description": [
                    "<p>The primary color used to generate the primary color palette (required).</p>",
                    ""
                ]
            },
            "secondary": {
                "description": [
                    "<p>The secondary color used to generate the secondary color palette (required).</p>",
                    ""
                ]
            },
            "surface": {
                "description": [
                    "<p>The color used as a background in components (required).</p>",
                    ""
                ]
            },
            "gray": {
                "description": [
                    "<p>The color used for generating the grayscale palette (optional).</p>",
                    ""
                ]
            },
            "info": {
                "description": [
                    "<p>The information color used throughout the application (optional).</p>",
                    ""
                ]
            },
            "success": {
                "description": [
                    "<p>The success color used throughout the application (optional).</p>",
                    ""
                ]
            },
            "warn": {
                "description": [
                    "<p>The warning color used throughout the application (optional).</p>",
                    ""
                ]
            },
            "error": {
                "description": [
                    "<p>The error color used throughout the application (optional).</p>",
                    ""
                ]
            },
            "variant": {
                "description": [
                    "<p>Used internally (optional).</p>",
                    ""
                ]
            }
        },
        "returns": {
            "description": [
                "<p>A map consisting of color shades for the passed base colors (primary, secondary, gray, etc).</p>",
                ""
            ]
        },
        "example": [
            {
                "code": [
                    "// Pass the required colors",
                    "$my-palette: palette(",
                    "  $primary: rebeccapurple,",
                    "  $secondary: orange,",
                    "  $surface: white,",
                    ");",
                    "",
                    "// Include the generated palette colors as CSS variables.",
                    "@include palette($my-palette);"
                ]
            }
        ]
    },
    "shades": {
        "description": [
            "<p>Generates color shades for a given color.</p>",
            ""
        ],
        "parameters": {
            "name": {
                "description": [
                    "<p>The name of the color.</p>",
                    ""
                ]
            },
            "color": {
                "description": [
                    "<p>The base color used to generate the shades.</p>",
                    ""
                ]
            },
            "shades": {
                "description": [
                    "<p>The list of shade variants.</p>",
                    ""
                ]
            },
            "surface": {
                "description": [
                    "<p>The surface color. Useful if generating shades of gray (optional).</p>",
                    ""
                ]
            }
        },
        "returns": {
            "description": [
                "<p>A map consisting of color shades and their respective contrast colors.</p>",
                ""
            ]
        },
        "example": [
            {
                "code": [
                    "$color-name: 'accent';",
                    "",
                    "// Include the generated palette colors as CSS variables.",
                    "@include palette(",
                    "  (",
                    "    #{$color-name}: shades($color-name, #a57865, $IColorShades),",
                    "  )",
                    ");"
                ]
            }
        ]
    },
    "color": {
        "description": [
            "<p>Retrieves a color from a color palette.</p>",
            ""
        ],
        "parameters": {
            "palette": {
                "description": [
                    "<p>The source palette map (optional).</p>",
                    ""
                ]
            },
            "color": {
                "description": [
                    "<p>The target color from the color palette.</p>",
                    ""
                ]
            },
            "variant": {
                "description": [
                    "<p>The target color shade from the color palette.</p>",
                    ""
                ]
            },
            "opacity": {
                "description": [
                    "<p>Optional opacity to apply to the color shade.</p>",
                    ""
                ]
            }
        },
        "returns": {
            "description": [
                "<p>The raw color shade or CSS variable reference from the palette.</p>",
                ""
            ]
        },
        "example": [
            {
                "description": [
                    "<p>Getting a color from the palette</p>",
                    ""
                ],
                "code": [
                    "// Without providing a palette",
                    ".my-component-1 {",
                    "   background: color($color: primary, $variant: 200); // var(--ig-primary-200)",
                    " }",
                    "",
                    " // With a specific palette",
                    ".my-component-2 {",
                    "   background: color($my-palette, primary, 200); // #88c0e5",
                    " }"
                ]
            },
            {
                "description": [
                    "<p>Getting a color with opacity</p>",
                    ""
                ],
                "code": [
                    ".my-component-1 {",
                    "   background: color($color: primary, $variant: 200, $opacity: 0.5); // hsl(from var(--ig-primary-200) h s l/0.5)",
                    " }",
                    "",
                    " // With a specific palette",
                    ".my-component-2 {",
                    "   background: color($my-palette, primary, 200, $opacity: 0.5); // rgba(136, 192, 229, 0.5)",
                    " }"
                ]
            }
        ]
    },
    "contrast-color": {
        "description": [
            "<p>Retrieves a contrast color for a given color variant from a color palette. Works similarly to the color function.</p>",
            ""
        ],
        "parameters": {
            "palette": {
                "description": [
                    "<p>The source palette map (optional).</p>",
                    ""
                ]
            },
            "color": {
                "description": [
                    "<p>The target color from the color palette.</p>",
                    ""
                ]
            },
            "variant": {
                "description": [
                    "<p>The target color shade from the color palette.</p>",
                    ""
                ]
            },
            "opacity": {
                "description": [
                    "<p>Optional opacity to apply to the color shade.</p>",
                    ""
                ]
            }
        },
        "returns": {
            "description": [
                "<p>The raw contrast color shade or CSS variable from the palette.</p>",
                ""
            ]
        },
        "example": [
            {
                "description": [
                    "<p>without passing a palette</p>",
                    ""
                ],
                "code": [
                    ".my-component {",
                    "   background: color($color: 'primary', $variant: 200);",
                    "   color: contrast-color($color: 'primary', $variant: 200);",
                    " }"
                ]
            }
        ]
    },
    "chart-brushes": {
        "description": [
            "<p>Returns a list of colors to be used as chart brushes. The return value depends on the value of enhanced-accessibility.</p>",
            ""
        ],
        "returns": {
            "description": [
                "<p>A list of colors to be used as chart brushes.</p>",
                ""
            ]
        }
    }
}