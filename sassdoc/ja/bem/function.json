{
    "elem": {
        "description": [
            "<p>BEM 要素セレクター文字列を返します。修飾子が指定されている場合は、要素セレクターに追加されます。</p>",
            ""
        ],
        "parameters": {
            "block": {
                "description": [
                    "<p>ブロックの名前。</p>",
                    ""
                ]
            },
            "elem": {
                "description": [
                    "<p>要素の名前。</p>",
                    ""
                ]
            },
            "mod": {
                "description": [
                    "<p>オプション。修飾の名前。</p>",
                    ""
                ]
            }
        },
        "returns": {
            "description": [
                "<p>BEM 要素セレクター文字列。</p>",
                ""
            ]
        },
        "example": [
            {
                "code": [
                    "elem('button', 'icon')        // returns '.button__icon'",
                    "elem('button', 'icon', 'big') // returns '.button__icon--big'"
                ]
            }
        ]
    },
    "mod": {
        "description": [
            "<p>ブロックの BEM 修飾子セレクター文字列を返します。</p>",
            ""
        ],
        "parameters": {
            "block": {
                "description": [
                    "<p>ブロックの名前。</p>",
                    ""
                ]
            },
            "mod": {
                "description": [
                    "<p>修飾の名前。</p>",
                    ""
                ]
            }
        },
        "returns": {
            "description": [
                "<p>BEM 修飾子セレクター文字列。</p>",
                ""
            ]
        },
        "example": [
            {
                "code": [
                    "mod('button', 'primary') // returns '.button--primary'",
                    "mod('card', 'outlined') // returns '.card--outlined'"
                ]
            }
        ]
    }
}