{
    "bem-block": {
        "description": [
            "<p>クラス セレクターとして展開します。このミックスインの主な目的は、",
            "BEM ブロックの開始を明確に示すことです。</p>",
            ""
        ],
        "parameters": {
            "block": {
                "description": [
                    "<p>ブロックの名前。</p>",
                    ""
                ]
            }
        },
        "example": [
            {
                "code": [
                    "@include bem-block(block) {",
                    "   background: green;",
                    "}",
                    "",
                    "// 出力",
                    ".block { background: green; }"
                ]
            }
        ]
    },
    "bem-elem": {
        "description": [
            "<p>コンテキストに基づいて BEM 要素セレクターになります。",
            "ブロックの中で、ルート レベルの <code>.block__elem</code> を作成します。",
            "Mod または疑似セレクターの中に入れ子にされた <code>.block--mod .block__elem</code> を作成します。",
            "$Mod を含む場合、ブロック セレクターに追加されます。複数 $mods はサポートしません。</p>",
            ""
        ],
        "parameters": {
            "elem": {
                "description": [
                    "<p>サブ要素の名前。</p>",
                    ""
                ]
            },
            "m": {
                "description": [
                    "<p>修飾の名前。</p>",
                    ""
                ]
            },
            "mod": {
                "description": [
                    "<p><code>$m</code> のエイリアス。</p>",
                    ""
                ]
            }
        },
        "example": [
            {
                "code": [
                    "@include bem-block(block) {",
                    "   @include bem-elem(element) {",
                    "     background: blue;",
                    "   }",
                    "}",
                    "// Return",
                    ".block__element { background: blue; }"
                ]
            }
        ]
    },
    "bem-mod": {
        "description": [
            "<p>オプションの除外を含む複数のブロック修飾子のセレクターを生成します。</p>",
            ""
        ],
        "parameters": {
            "mods": {
                "description": [
                    "<p>修飾子名のリスト。</p>",
                    ""
                ]
            },
            "options": {
                "description": [
                    "<p>オプションの構成マップ。</p>",
                    ""
                ]
            },
            "options.not": {
                "description": [
                    "<p>:not() で除外する修飾子。</p>",
                    ""
                ]
            }
        },
        "example": [
            {
                "code": [
                    "@include bem-block(card) {",
                    "  @include bem-mods(large, primary, (not: outline)) {",
                    "    // Applies to .card--large, .card--primary",
                    "    // but not when .card--outline is present",
                    "  }",
                    "}"
                ]
            }
        ]
    },
    "bem-mods": {
        "description": [
            "<p>block--modifier.[block--modifier...] .block__el になります。",
            "Mixin はブロックまたはブロック要素に 2 つ以上の修飾は同時に適用されるときに役に立ちます。</p>",
            ""
        ],
        "parameters": {
            "mods": {
                "description": [
                    "<p>修飾のリスト。</p>",
                    ""
                ]
            }
        },
        "example": [
            {
                "code": [
                    "@include bem-block(block) {",
                    "   @include bem-mods(error, warn) {",
                    "     position: absolute;",
                    "   }",
                    "}",
                    "// Return",
                    ".block--error,",
                    ".block--warn {",
                    "    position: absolute;",
                    " }"
                ]
            }
        ]
    },
    "bem": {
        "description": [
            "<p>完全 BEM ルールを生成します。</p>",
            ""
        ],
        "parameters": {
            "block": {
                "description": [
                    "<p>文字列ブロックの名前。必須。</p>",
                    ""
                ]
            },
            "elem": {
                "description": [
                    "<p>サブ要素の名前。<code>$mod</code> が存在しない場合は、",
                    "$block と結合されます。$mod が存在する場合、それは <code>$block--$mod</code> の下にネストされます。</p>",
                    ""
                ]
            },
            "mod": {
                "description": [
                    "<p>ブロック修飾。</p>",
                    ""
                ]
            },
            "mods": {
                "description": [
                    "<p>ブロック修飾のリスト。</p>",
                    ""
                ]
            }
        },
        "example": [
            {
                "description": [
                    "<p>ブロックを含みます。</p>",
                    ""
                ],
                "code": [
                    "@include bem(block) {",
                    "  background: blue;",
                    "};",
                    "",
                    "// 出力",
                    ".block {",
                    "  background: blue;",
                    "}"
                ]
            },
            {
                "description": [
                    "<p>要素とブロックを含みます。</p>",
                    ""
                ],
                "code": [
                    " @include bem(block, $elem: elem) {",
                    "   background: blue;",
                    " }",
                    "",
                    "// 出力",
                    " .block__elem {",
                    "   background: blue;",
                    " }"
                ]
            },
            {
                "description": [
                    "<p>ブロック、要素と要素修飾を含みます。</p>",
                    ""
                ],
                "code": [
                    "@include bem(block, $elem: (elem, mod)) {",
                    "  background: blue;",
                    "}",
                    "",
                    "// 出力",
                    ".block__elem--mod {",
                    "  background: blue;",
                    "}"
                ]
            },
            {
                "description": [
                    "<p>ブロックとブロック修飾を含みます。</p>",
                    ""
                ],
                "code": [
                    "@include bem(block, $mod: mod) {",
                    "  background: blue;",
                    "}",
                    "",
                    "// 出力",
                    ".block--mod {",
                    "  background: blue;",
                    "}"
                ]
            },
            {
                "description": [
                    "<p>複数の修飾子を持つブロックを含みます。</p>",
                    ""
                ],
                "code": [
                    "@include bem(block, $mods: (mod-1, mod-2)) {",
                    "   background: blue;",
                    " }",
                    "",
                    " // 出力",
                    " .block--mod-1.block--mod-2 {",
                    "   background: blue;",
                    " }"
                ]
            },
            {
                "description": [
                    "<p>ブロック修飾を続くブロック サブ要素を含みます。</p>",
                    ""
                ],
                "code": [
                    "@include bem(block, $m:mod, $e:elem) {",
                    "  background: blue;",
                    "}",
                    "",
                    "// 出力",
                    ".block--mod .block__elem {",
                    "  background: blue;",
                    "}"
                ]
            }
        ]
    },
    "block": {
        "description": [
            "<p>bem-block と同じです。</p>",
            ""
        ]
    },
    "elem": {
        "description": [
            "<p>bem-elem と同じです。</p>",
            ""
        ]
    },
    "mod": {
        "description": [
            "<p>bem-mod と同じです。</p>",
            ""
        ]
    },
    "mods": {
        "description": [
            "<p>bem-mods と同じです。</p>",
            ""
        ]
    },
    "b": {
        "description": [
            "<p>bem-block と同じです。</p>",
            ""
        ]
    },
    "e": {
        "description": [
            "<p>bem-elem と同じです。</p>",
            ""
        ]
    },
    "m": {
        "description": [
            "<p>bem-mod と同じです。</p>",
            ""
        ]
    },
    "mx": {
        "description": [
            "<p>bem-mods と同じです。</p>",
            ""
        ]
    }
}