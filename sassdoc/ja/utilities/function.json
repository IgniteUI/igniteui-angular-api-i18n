    "is-root": {
        "description": [
            "呼ばれた範囲がドキュメントのルートの場合、true を返します。",
            ""
        ],
        "returns": {
            "description": [
                "呼び出されたスコープに応じてブール値を返します。"
            ]
        },
        "example": [
            {
                "description": [
                    "現在の範囲がルートであるかどうかをチェックします。"
                ],
                "code": [
                    "@mixin smart-mixin() {",
                    "  $scope: if(is-root(), ':root', '&');",
                    "",
                    "  #{$scope} {",
                    "    /* style rules here */",
                    "  }",
                    "}"
                ]
            }
        ]
    },
    "is-host": {
        "description": [
            "呼び出し元のスコープが :host の場合に true を返します。",
            ""
        ],
        "returns": {
            "description": [
                "呼び出されたスコープに応じてブール値を返します。"
            ]
        },
        "example": [
            {
                "description": [
                    "現在の範囲が :root であるかどうかをチェックします。"
                ],
                "code": [
                    "@mixin smart-mixin() {",
                    "  $host: is-host();",
                    "",
                    "  @if is-host() {",
                    "    /* style rules here */",
                    "  }",
                    "}"
                ]
            }
        ]
    },
