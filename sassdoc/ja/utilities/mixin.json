{
    "line-clamp": {
        "description": [
            "特定の行数でテキストを切り捨てます。",
            ""
        ],
        "parameters": {
            "lines": {
                "description": [
                    "表示する行数。"
                ]
            },
            "inline": {
                "description": [
                    "要素が inline-box または box を表示するかどうかを設定します。"
                ]
            },
            "vertical": {
                "description": [
                    "要素がコンテンツを水平または垂直に配置するかどうかを設定します。"
                ]
            }
        },
        "example": [
            {
                "description": [
                    "4 行目以降のテキストを切り捨てます。"
                ],
                "code": [
                    "@include line-clamp(4, true, true);"
                ]
            }
        ]
    },
    "ellipsis": {
        "description": [
            "E テキスト要素に text-overflow 省略記号を適用します。",
            "この処理は display flex の要素には機能しません。",
            ""
        ],
        "example": [
            {
                "code": [
                    ".my-class {",
                    "  @include ellipsis();",
                    "}"
                ]
            }
        ]
    },
    "hide-default": {
        "description": [
            "DOM から要素を非表示にします。",
            ""
        ],
        "example": [
            {
                "description": [
                    "例"
                ],
                "code": [
                    "input[type=\"checkbox\"] {",
                    "  @include hide-default();",
                    "}"
                ]
            }
        ]
    }
}