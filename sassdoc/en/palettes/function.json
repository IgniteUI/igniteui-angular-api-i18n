{
    "palette": {
        "description": [
            "Generates a color palette.",
            ""
        ],
        "parameters": {
            "primary": {
                "description": [
                    "The primary color used to generate the primary color palette (required)."
                ]
            },
            "secondary": {
                "description": [
                    "The secondary color used to generate the secondary color palette (required)."
                ]
            },
            "surface": {
                "description": [
                    "The color used as a background in components (required)."
                ]
            },
            "gray": {
                "description": [
                    "The color used for generating the grayscale palette (optional)."
                ]
            },
            "info": {
                "description": [
                    "The information color used throughout the application (optional)."
                ]
            },
            "success": {
                "description": [
                    "The success color used throughout the application (optional)."
                ]
            },
            "warn": {
                "description": [
                    "The warning color used throughout the application (optional)."
                ]
            },
            "error": {
                "description": [
                    "The error color used throughout the application (optional)."
                ]
            },
            "variant": {
                "description": [
                    "Used internally (optional)."
                ]
            }
        },
        "returns": {
            "description": [
                "A map consisting of color shades for the passed base colors (primary, secondary, gray, etc)."
            ]
        },
        "example": [
            {
                "code": [
                    "// Pass the required colors",
                    "$my-palette: palette(",
                    "  $primary: rebeccapurple,",
                    "  $secondary: orange,",
                    "  $surface: white,",
                    ");",
                    "",
                    "// Include the generated palette colors as CSS variables.",
                    "@include palette($my-palette);"
                ]
            }
        ]
    },
    "shades": {
        "description": [
            "Generates color shades for a given color.",
            ""
        ],
        "parameters": {
            "name": {
                "description": [
                    "The name of the color."
                ]
            },
            "color": {
                "description": [
                    "The base color used to generate the shades."
                ]
            },
            "shades": {
                "description": [
                    "The list of shade variants."
                ]
            },
            "surface": {
                "description": [
                    "The surface color. Useful if generating shades of gray (optional)."
                ]
            }
        },
        "returns": {
            "description": [
                "A map consisting of color shades and their respective contrast colors.",
                ""
            ]
        },
        "example": [
            {
                "code": [
                    "$color-name: 'accent';",
                    "",
                    "// Include the generated palette colors as CSS variables.",
                    "@include palette(",
                    "  (",
                    "    #{$color-name}: shades($color-name, #a57865, $IColorShades),",
                    "  )",
                    ");"
                ]
            }
        ]
    },
    "shade": {
        "description": [
            "Generates a color shade for a given base colors.",
            ""
        ],
        "parameters": {
            "name": {
                "description": [
                    "The base color name (primary, secondary, etc.) to be used to generate a color variant."
                ]
            },
            "color": {
                "description": [
                    "The color value to be used to generate a color shade."
                ]
            },
            "shade": {
                "description": [
                    "The color shade variant."
                ]
            },
            "surface": {
                "description": [
                    "The surface color. Useful when generating a shade of gray (optional)."
                ]
            }
        },
        "returns": {
            "description": [
                "A map containing a list of HSL values and a raw color value."
            ]
        }
    },
    "color": {
        "description": [
            "Retrieves a color from a color palette.",
            ""
        ],
        "parameters": {
            "palette": {
                "description": [
                    "The source palette map (optional)."
                ]
            },
            "color": {
                "description": [
                    "The target color from the color palette."
                ]
            },
            "variant": {
                "description": [
                    "The target color shade from the color palette."
                ]
            },
            "opacity": {
                "description": [
                    "Optional opacity to apply to the color shade."
                ]
            }
        },
        "returns": {
            "description": [
                "The raw color shade or CSS variable reference from the palette.",
                ""
            ]
        },
        "example": [
            {
                "description": [
                    "Getting a color from the palette"
                ],
                "code": [
                    "// Without providing a palette",
                    ".my-component-1 {",
                    "   background: color($color: primary, $variant: 200); // var(--ig-primary-200)",
                    " }",
                    "",
                    " // With a specific palette",
                    ".my-component-2 {",
                    "   background: color($my-palette, primary, 200); // #88c0e5",
                    " }"
                ]
            },
            {
                "description": [
                    "Getting a color with opacity"
                ],
                "code": [
                    ".my-component-1 {",
                    "   background: color($color: primary, $variant: 200, $opacity: 0.5); // hsl(from var(--ig-primary-200) h s l/0.5)",
                    " }",
                    "",
                    " // With a specific palette",
                    ".my-component-2 {",
                    "   background: color($my-palette, primary, 200, $opacity: 0.5); // rgba(136, 192, 229, 0.5)",
                    " }"
                ]
            }
        ]
    },
    "contrast-color": {
        "description": [
            "Retrieves a contrast color for a given color variant from a color palette. Works similarly to the color function.",
            ""
        ],
        "parameters": {
            "palette": {
                "description": [
                    "The source palette map (optional)."
                ]
            },
            "color": {
                "description": [
                    "The target color from the color palette."
                ]
            },
            "variant": {
                "description": [
                    "The target color shade from the color palette."
                ]
            },
            "opacity": {
                "description": [
                    "Optional opacity to apply to the color shade."
                ]
            }
        },
        "returns": {
            "description": [
                "The raw contrast color shade or CSS variable from the palette.",
                ""
            ]
        },
        "example": [
            {
                "description": [
                    "without passing a palette"
                ],
                "code": [
                    ".my-component {",
                    "   background: color($color: 'primary', $variant: 200);",
                    "   color: contrast-color($color: 'primary', $variant: 200);",
                    " }"
                ]
            }
        ]
    },
    "chart-brushes": {
        "description": [
            "Returns a list of colors to be used as chart brushes. The return value depends on the value of enhanced-accessibility.",
            ""
        ],
        "returns": {
            "description": [
                "A list of colors to be used as chart brushes."
            ]
        }
    }
}