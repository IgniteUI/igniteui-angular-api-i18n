{
    "palette": {
        "description": [
            "<p>カラー パレットを生成します。</p>",
            ""
        ],
        "parameters": {
            "primary": {
                "description": [
                    "<p>基本パレットの生成に使用する primary カラー (必須)。</p>",
                    ""
                ]
            },
            "secondary": {
                "description": [
                    "<p>二次色パレットの生成に使用する secondary カラー (必須)。</p>",
                    ""
                ]
            },
            "surface": {
                "description": [
                    "<p>コンポーネントに使用されるカラー (必須)。</p>",
                    ""
                ]
            },
            "gray": {
                "description": [
                    "<p>グレースケール パレットの生成に使用するカラー (オプション)。</p>",
                    ""
                ]
            },
            "info": {
                "description": [
                    "<p>アプリケーション内で使用する information カラー (オプション)。</p>",
                    ""
                ]
            },
            "success": {
                "description": [
                    "<p>アプリケーション内で使用する success カラー (オプション)。</p>",
                    ""
                ]
            },
            "warn": {
                "description": [
                    "<p>アプリケーション内で使用する warning カラー (オプション)。</p>",
                    ""
                ]
            },
            "error": {
                "description": [
                    "<p>アプリケーション内で使用する error カラー (オプション)。</p>",
                    ""
                ]
            },
            "variant": {
                "description": [
                    "<p>内部で使用されます (オプション)。</p>",
                    ""
                ]
            }
        },
        "returns": {
            "description": [
                "<p>渡された基本色 (primary、secondary、gray など) の色合いで構成されるマップ。</p>",
                ""
            ]
        },
        "example": [
            {
                "code": [
                    "// 必要な色を渡します。",
                    "$my-palette: palette(",
                    "  $primary: rebeccapurple,",
                    "  $secondary: orange,",
                    "  $surface: white,",
                    ");",
                    "",
                    "// 生成されたパレットの色を CSS 変数として含めます。",
                    "@include palette($my-palette);"
                ]
            }
        ]
    },
    "shades": {
        "description": [
            "<p>指定された色の色合いを生成します。</p>",
            ""
        ],
        "parameters": {
            "name": {
                "description": [
                    "<p>カラーの名前。</p>",
                    ""
                ]
            },
            "color": {
                "description": [
                    "<p>色合いの生成に使用する基本色。</p>",
                    ""
                ]
            },
            "shades": {
                "description": [
                    "<p>色合いバリアントのリスト。</p>",
                    ""
                ]
            },
            "surface": {
                "description": [
                    "<p>surface のカラー。gray の色合いを生成する場合に便利です (オプション)。</p>",
                    ""
                ]
            }
        },
        "returns": {
            "description": [
                "<p>色合いとそれぞれのコントラスト カラーで構成されるマップ。</p>",
                ""
            ]
        },
        "example": [
            {
                "code": [
                    "$color-name: 'accent';",
                    "",
                    "// 生成されたパレットの色を CSS 変数として含みます。",
                    "@include palette(",
                    "  (",
                    "    #{$color-name}: shades($color-name, #a57865, $IColorShades),",
                    "  )",
                    ");"
                ]
            }
        ]
    },
    "color": {
        "description": [
            "<p>カラーパレットから色を取得します。</p>",
            ""
        ],
        "parameters": {
            "palette": {
                "description": [
                    "<p>ソースのパレット マップ (オプション)。</p>",
                    ""
                ]
            },
            "color": {
                "description": [
                    "<p>カラー パレットからターゲット色を取得します。</p>",
                    ""
                ]
            },
            "variant": {
                "description": [
                    "<p>カラー パレットからのターゲット色の影</p>",
                    ""
                ]
            },
            "opacity": {
                "description": [
                    "<p>色合いに適用するオプションの不透明度。</p>",
                    ""
                ]
            }
        },
        "returns": {
            "description": [
                "<p>パレットからの生の色合いまたは CSS 変数参照。</p>",
                ""
            ]
        },
        "example": [
            {
                "description": [
                    "<p>パレットから色を取得する方法</p>",
                    ""
                ],
                "code": [
                    "// パレットを指定せずに取得する場合",
                    ".my-component-1 {",
                    "   background: color($color: primary, $variant: 200); // var(--ig-primary-200)",
                    " }",
                    "",
                    " // 特定のパレットを使用して取得する場合",
                    ".my-component-2 {",
                    "   background: color($my-palette, primary, 200); // #88c0e5",
                    " }"
                ]
            },
            {
                "description": [
                    "<p>不透明度を指定して色を取得する方法</p>",
                    ""
                ],
                "code": [
                    ".my-component-1 {",
                    "   background: color($color: primary, $variant: 200, $opacity: 0.5); // hsl(from var(--ig-primary-200) h s l/0.5)",
                    " }",
                    "",
                    " // 特定のパレットを使用して取得する場合",
                    ".my-component-2 {",
                    "   background: color($my-palette, primary, 200, $opacity: 0.5); // rgba(136, 192, 229, 0.5)",
                    " }"
                ]
            }
        ]
    },
    "contrast-color": {
        "description": [
            "<p>カラー レットから指定のカラー バリアントのためコントラストの色を取得します。color 関数と同様に動作します。</p>",
            ""
        ],
        "parameters": {
            "palette": {
                "description": [
                    "<p>ソースのパレット マップ (オプション)。</p>",
                    ""
                ]
            },
            "color": {
                "description": [
                    "<p>カラー パレットからターゲット色を取得します。</p>",
                    ""
                ]
            },
            "variant": {
                "description": [
                    "<p>カラー パレットからのターゲット色の影。</p>",
                    ""
                ]
            },
            "opacity": {
                "description": [
                    "<p>色合いに適用するオプションの不透明度。</p>",
                    ""
                ]
            }
        },
        "returns": {
            "description": [
                "<p>パレットからの生のコントラスト色合いまたは CSS 変数。</p>",
                ""
            ]
        },
        "example": [
            {
                "description": [
                    "<p>パレットを通さずに</p>",
                    ""
                ],
                "code": [
                    ".my-component {",
                    "   background: color($color: 'primary', $variant: 200);",
                    "   color: contrast-color($color: 'primary', $variant: 200);",
                    " }"
                ]
            }
        ]
    },
    "chart-brushes": {
        "description": [
            "<p>チャート ブラシとして使用される色のリストを返します。戻り値は、enhanced-accessibility の値によって異なります。</p>",
            ""
        ],
        "returns": {
            "description": [
                "<p>チャート ブラシとして使用される カラーのリスト。</p>",
                ""
            ]
        }
    }
}