{
    "em": {
        "description": [
            "Converts pixels to relative values (em).",
            ""
        ],
        "parameters": {
            "pixels": {
                "description": [
                    "The pixel value to be converted."
                ]
            },
            "context": {
                "description": [
                    "The base context to convert against."
                ]
            }
        },
        "returns": {
            "description": [
                "Returns the pixels value converted to em."
            ]
        },
        "example": [
            {
                "code": [
                    ".my-component {",
                    "  margin: em(10px) em(5px);",
                    "}",
                    "",
                    "// Output",
                    ".my-component {",
                    "  margin: 0.625em 0.3125em;",
                    "}"
                ]
            }
        ]
    },
    "rem": {
        "description": [
            "Converts pixels to root relative values (rem).",
            ""
        ],
        "parameters": {
            "pixels": {
                "description": [
                    "The pixel value to be converted."
                ]
            },
            "context": {
                "description": [
                    "The base context to convert against."
                ]
            }
        },
        "returns": {
            "description": [
                "Returns the pixels value converted to rem."
            ]
        },
        "example": [
            {
                "code": [
                    ".my-component {",
                    "  margin: rem(10px) rem(5px);",
                    "}",
                    "",
                    "// Output",
                    ".my-component {",
                    "  margin: 0.625rem 0.3125rem;",
                    "}"
                ]
            }
        ]
    },
    "px": {
        "description": [
            "Converts relative value (em/rem) to pixel.",
            ""
        ],
        "parameters": {
            "num": {
                "description": [
                    "The relative value to be converted."
                ]
            },
            "context": {
                "description": [
                    "The base context to convert against."
                ]
            }
        },
        "returns": {
            "description": [
                "Returns the relative value converted to pixels."
            ]
        },
        "example": [
            {
                "code": [
                    ".my-component {",
                    "  margin: px(3rem);",
                    "}",
                    "",
                    "// Output",
                    ".my-component {",
                    "  margin: 48px;",
                    "}"
                ]
            }
        ]
    },
    "type-style": {
        "description": [
            "Produces a type style map of values that adheres to the ITypeStyle map.",
            ""
        ],
        "parameters": {
            "font-family": {
                "description": [
                    "The font family of the type style."
                ]
            },
            "font-size": {
                "description": [
                    "The font size of the type style."
                ]
            },
            "font-weight": {
                "description": [
                    "The font weight of the type style."
                ]
            },
            "font-style": {
                "description": [
                    "The font style of the type style."
                ]
            },
            "line-height": {
                "description": [
                    "The line height of the type style."
                ]
            },
            "letter-spacing": {
                "description": [
                    "The letter spacing of the type style."
                ]
            },
            "text-transform": {
                "description": [
                    "The text-transform property of the type style."
                ]
            },
            "margin-top": {
                "description": [
                    "The margin-top property of the type style."
                ]
            },
            "margin-bottom": {
                "description": [
                    "The margin-bottom property of the type style."
                ]
            }
        },
        "returns": {
            "description": [
                "A map of all defined type style properties."
            ]
        },
        "example": [
            {
                "code": [
                    "$main_navigation: type-style(",
                    "   $font-size: rem(14px),",
                    "   $font-weight: 600,",
                    "   $letter-spacing: rem(.1px),",
                    "   $line-height: rem(14px),",
                    "   $text-transform: none,",
                    ");",
                    "",
                    "// Use the type-style() mixin to consume the new type style produced from the type-style() function.",
                    ".main-nav {",
                    "  @include type-style($main_navigation);",
                    "}"
                ]
            }
        ]
    },
    "type-scale": {
        "description": [
            "Produces a type scale map containing type styles that adheres to the ITypeScale list.",
            ""
        ],
        "parameters": {
            "h1": {
                "description": [
                    "A map containing type style properties as produced by the type-style function."
                ]
            },
            "h2": {
                "description": [
                    "A map containing type style properties as produced by the type-style function."
                ]
            },
            "h3": {
                "description": [
                    "A map containing type style properties as produced by the type-style function."
                ]
            },
            "h4": {
                "description": [
                    "A map containing type style properties as produced by the type-style function."
                ]
            },
            "h5": {
                "description": [
                    "A map containing type style properties as produced by the type-style function."
                ]
            },
            "h6": {
                "description": [
                    "A map containing type style properties as produced by the type-style function."
                ]
            },
            "subtitle-1": {
                "description": [
                    "A map containing type style properties as produces by the type-style function."
                ]
            },
            "subtitle-2": {
                "description": [
                    "A map containing type style properties as produces by the type-style function."
                ]
            },
            "body-1": {
                "description": [
                    "A map containing type style properties as produces by the type-style function."
                ]
            },
            "body-2": {
                "description": [
                    "A map containing type style properties as produces by the type-style function."
                ]
            },
            "button": {
                "description": [
                    "A map containing type style properties as produces by the type-style function."
                ]
            },
            "caption": {
                "description": [
                    "A map containing type style properties as produces by the type-style function."
                ]
            },
            "overline": {
                "description": [
                    "A map containing type style properties as produces by the type-style function."
                ]
            },
            "_theme": {
                "description": [
                    "The theme related to this type scale. Internal use only."
                ]
            }
        },
        "returns": {
            "description": [
                "A map of all defined type scales."
            ]
        },
        "example": [
            {
                "code": [
                    "// First define type styles to use",
                    "$my-body-1: type-style(",
                    "   $font-size: rem(14px),",
                    ");",
                    "",
                    "// Use the type style map to override one of the existing maps",
                    "$type-scale: type-scale(",
                    "  ...",
                    "  $body-1: $my-body-1,",
                    "  ...",
                    ");"
                ]
            }
        ]
    },
    "type-scale-category": {
        "description": [
            "Get type scale category config.",
            ""
        ],
        "parameters": {
            "scale": {
                "description": [
                    "A type scale map reference as produces by type-scale."
                ]
            },
            "category": {
                "description": [
                    "The scale category you want config for. For instance - 'h1';"
                ]
            }
        },
        "returns": {
            "description": [
                "The config map for the selected category in the type scale."
            ]
        },
        "example": [
            {
                "description": [
                    "Get the type scale category config for the `h1` scale."
                ],
                "code": [
                    "$h1-type-scale: type-scale-category($type-scale, 'h1');"
                ]
            }
        ]
    }
}