    "type-style": {
        "description": [
            "カテゴリに関連するすべてのスタイルを現在のスタイル ブロックに含めます。",
            ""
        ],
        "parameters": {
            "category": {
                "description": [
                    "タイプ スケールのカテゴリ。"
                ]
            },
            "check": {
                "description": [
                    "ITypeScale に対するカテゴリ チェックを切り替えます。",
                    "カスタム タイプ スケールを使用する場合は false に設定します。"
                ]
            }
        },
        "example": [
            {
                "description": [
                    "カスタム CSS セレクターに `h1` スタイルを追加します。"
                ],
                "code": [
                    ".fancy-h1 {",
                    "   @include type-style('h1');",
                    "",
                    "   color: mediumvioletred;",
                    "}"
                ]
            }
        ]
    },
    "type-style-vars": {
        "description": [
            "タイプ スタイル マップを CSS フォント変数に変換します。",
            ""
        ],
        "parameters": {
            "name": {
                "description": [
                    "カスタム CSS 変数名。"
                ]
            },
            "type-style": {
                "description": [
                    "type-style によって生成される style 型のマップ参照。"
                ]
            }
        },
        "example": [
            {
                "description": [
                    "CSS フォントの省略構文を使用して、`h1` スタイルをカスタム CSS プロパティに割り当てます。"
                ],
                "code": [
                    "$h1-style: type-scale-category($type-scale, 'h1');",
                    "@include type-style-vars('h1', $h1-style);"
                ]
            }
        ]
    },
    "type-style-elements": {
        "description": [
            "IElementCategories マップに一致するすべてのネイティブ要素をスタイルします。",
            ""
        ],
        "example": [
            {
                "description": [
                    "すべてのネイティブ要素にタイプスタイルを適用します。"
                ],
                "code": [
                    ".ig-typography {",
                    "  @include type-style-elements();",
                    "}"
                ]
            }
        ]
    },
    "type-style-classes": {
        "description": [
            "ITypeScale マップ内のすべてのカテゴリのスタイル ルールを持つ CSS クラスを作成します。",
            ""
        ],
        "example": [
            {
                "description": [
                    "すべてのタイプ スタイルの CSS クラスを作成します。"
                ],
                "code": [
                    ".ig-typography {",
                    "  @include type-style-classes();",
                    "}"
                ]
            }
        ]
    },
    "font-var": {
        "description": [
            "タイプ スタイルのマップを CSS 変数に割り当てられたフォント スタイル ルールに変換します。",
            ""
        ],
        "parameters": {
            "name": {
                "description": [
                    "カスタム CSS 変数名。"
                ]
            },
            "type-style": {
                "description": [
                    "type-style によって生成されるタイプ スタイルのマップ参照。"
                ]
            },
            "prefix": {
                "description": [
                    "任意のプレフィックス。"
                ]
            }
        },
        "example": [
            {
                "description": [
                    "CSS フォントの省略構文を使用して、`h1` スタイルをカスタム CSS プロパティに割り当てます。"
                ],
                "code": [
                    "$h1-style: type-scale-category($type-scale, 'h1');",
                    "@include font-var('h1-font', $h1-style);"
                ]
            }
        ]
    },
    "typography": {
        "description": [
            "h1-h6 のためにタイポグラフィ スタイルを追加して、カスタム タイポグラフィ クラス セレクターを作成します。",
            "生成されたスタイルは、渡された書体とタイプ スケールに基づきます。",
            ""
        ],
        "parameters": {
            "font-family": {
                "description": [
                    "すべてのタイポグラフィ要素中に使用されるフォント ファミリ。"
                ]
            },
            "type-scale": {
                "description": [
                    "type-scale 関数で生成されるタイプ スケールのマップ。"
                ]
            }
        },
        "example": [
            {
                "code": [
                    "@include typography('Roboto', $my-type-scale);"
                ]
            }
        ]
    },
    "charts-typography": {
        "description": [
            "特定のタイプ スケールとターゲットのすべてのチャート関連のタイポグラフィ スタイルが含まれます。",
            ""
        ],
        "parameters": {
            "type-scale": {
                "description": [
                    "タイポグラフィ スタイルを含めるときに使用するタイプ スケール。"
                ]
            },
            "target": {
                "description": [
                    "ターゲット プラットフォーム。'angular'、'webc'、または 'blazor' のいずれかです。"
                ]
            }
        }
    }
