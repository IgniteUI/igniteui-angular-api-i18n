{
    "bem--sep-elem": {
        "description": [
            "The Element separator used. Default '__'.",
            ""
        ],
        "example": [
            {
                "description": [
                    "Change the element separator from '__' to '-'"
                ],
                "code": [
                    "$bem--sep-elem: '-';",
                    "",
                    "@include b(block) {",
                    "   @include e(element) {",
                    "     background: blue;",
                    "   }",
                    "}",
                    "",
                    "// Generated CSS",
                    ".block-element { background: blue; }"
                ]
            }
        ]
    },
    "bem--sep-mod": {
        "description": [
            "The Modifier separator used. Default '--'.",
            ""
        ],
        "example": [
            {
                "description": [
                    "Change the modifier separator from '--' to '---'"
                ],
                "code": [
                    "$bem--sep-mod: '---';",
                    "",
                    "@include b(block) {",
                    "   @include m(modifier) {",
                    "     background: red;",
                    "   }",
                    "}",
                    "",
                    "// Generated CSS",
                    ".block---modifier { background: red; }"
                ]
            }
        ]
    },
    "bem--sep-mod-val": {
        "description": [
            "The Modifier Value separator used. Default '-'.",
            ""
        ],
        "example": [
            {
                "description": [
                    "Change the modifier value separator from '-' to '_'"
                ],
                "code": [
                    "$bem--sep-mod-val: '_';",
                    "",
                    "@include b(block) {",
                    "   @include m(modifier, value) {",
                    "     background: red;",
                    "   }",
                    "}",
                    "",
                    "// Generated CSS",
                    ".block--modifier_value { background: red; }"
                ]
            }
        ]
    },
    "_bem-mod-cache": {
        "description": [
            "Cache for modifier string conversions",
            ""
        ]
    }
}