    "expand-shorthand": {
        "description": [
            "指定された値のリストを上下左右の 4 方向に展開します。",
            "マージンのショートハンドがブラウザによって展開される方法と同様の動作をします。",
            ""
        ],
        "parameters": {
            "list": {
                "description": [
                    "展開対象となる値のリスト。最大 4 つの値をサポートします。"
                ]
            },
            "prop": {
                "description": [
                    "プロパティの名前。"
                ]
            }
        },
        "returns": {
            "description": [
                "展開された値のリストを返します。"
            ]
        }
    },
    "clean": {
        "description": [
            "マップからすべての null キーと値のペアを削除します。",
            ""
        ],
        "parameters": {
            "map": {
                "description": [
                    "クリーンアップするターゲット マップ。"
                ]
            }
        },
        "returns": {
            "description": [
                "null キーと値のペアが削除されたマップを返します。"
            ]
        }
    },
    "extend": {
        "description": [
            "プロセスで null 値を無視して、別の Map の値で Map を拡張します。",
            ""
        ],
        "parameters": {
            "maps": {
                "description": [
                    "継承されるマップ。"
                ]
            }
        },
        "returns": {
            "description": [
                "結合済みのマップを返します。"
            ]
        }
    },
    "diff": {
        "description": [
            "2 つ以上のマップ間の差異を抽出して最初のマップと残りのマップ比較します。",
            ""
        ],
        "parameters": {
            "maps": {
                "description": [
                    "差分されるマップのリスト。"
                ]
            }
        },
        "returns": {
            "description": [
                "固有のプロパティのマップを返します。"
            ]
        },
        "example": [
            {
                "description": [
                    "最初のマップと比較したときの、2 番目のマップの固有のプロパティを引き出します。"
                ],
                "code": [
                    "$map-1: (",
                    "  color: orange,",
                    "  background: black,",
                    ");",
                    "",
                    "$map-2: (",
                    "  color: red,",
                    "  background: black,",
                    ");",
                    "",
                    "$diffed: diff($map-1, $map-2); // returns (color: red);"
                ]
            }
        ]
    },
