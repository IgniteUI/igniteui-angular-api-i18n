{
    "_is-shadow": {
        "description": [
            "渡された引数が有効な box-shadow かどうかをチェックします。",
            ""
        ],
        "parameters": {
            "shadow": {
                "description": [
                    "shadow プロパティのリスト。"
                ]
            }
        },
        "returns": {
            "description": [
                "渡された引数が有効な shadow であるかどうかを示すブール値を返します。"
            ]
        }
    },
    "_transform-shadow": {
        "description": [
            "渡された box-shadow のリストを、エレベーション係数の値に従って変換します。",
            ""
        ],
        "parameters": {
            "shadow": {
                "description": [
                    "shadow プロパティのリスト。"
                ]
            }
        },
        "returns": {
            "description": [
                "変換された shadow リスト。"
            ]
        }
    },
    "box-shadow": {
        "description": [
            "有効な box-shadow のみのリストをソートします。",
            ""
        ],
        "parameters": {
            "shadows": {
                "description": [
                    "shadow 値のリスト。"
                ]
            }
        },
        "returns": {
            "description": [
                "変換された shadow リスト。"
            ]
        },
        "example": [
            {
                "code": [
                    ".my-component {",
                    "  box-shadow: box-shadow((0 0 2px 3px black, 0 6px 9px orange));",
                    "}",
                    "",
                    "// 出力",
                    ".my-component {",
                    "  box-shadow:",
                    "      0 0 calc(--ig-elevation-factor * 2px) calc(--ig-elevation-factor * 3px) black,",
                    "      0 calc(--ig-elevation-factor * 6px) calc(--ig-elevation-factor * 9px) orange;",
                    "}"
                ]
            }
        ]
    },
    "elevation": {
        "description": [
            "名前で CSS エレベーション変数を取得します。",
            ""
        ],
        "parameters": {
            "name": {
                "description": [
                    "shadow の名前。"
                ]
            }
        },
        "returns": {
            "description": [
                "CSS エレベーション変数。"
            ]
        },
        "example": [
            {
                "code": [
                    ".my-component {",
                    "  box-shadow: elevation(5); // var(--ig-elevation-5)",
                    "}"
                ]
            }
        ]
    }
}