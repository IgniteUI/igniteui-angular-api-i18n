        "description": [
            "shape-chart コンポーネントにタイポグラフィのスタイルを追加します。",
            "タイポグラフィ スケールから 'h3'、'h4'、'h6' および 'subtitle-1'",
            "カテゴリを使用します。",
            ""
        ],
        "parameters": {
            "type-scale": {
                "description": [
                    "igx-type-scale が生成されるタイポグラフィ スケール。"
                ]
            },
