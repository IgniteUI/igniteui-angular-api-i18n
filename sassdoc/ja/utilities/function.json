                ]
            }
        },
        "returns": {
            "description": [
                "評価された値。"
            ]
        },
        "example": [
            {
                "code": [
                    ".my-component {",
                    "  padding: pad-inline(4px, 8px, 16px);",
                    "}"
                ]
            }
        ]
    },
