    "expand-shorthand": {
        "description": [
            "Expands the provided list of values in all four directions.",
            "Works similar to how to browser expands shorthands for margins.",
            ""
        ],
        "parameters": {
            "list": {
                "description": [
                    "The of values to be expanded. Supports up to four values."
                ]
            },
            "prop": {
                "description": [
                    "The name of the property."
                ]
            }
        },
        "returns": {
            "description": [
                "Returns an expanded list of values."
            ]
        }
    },
    "clean": {
        "description": [
            "Removes all null key-value pairs from a map",
            ""
        ],
        "parameters": {
            "map": {
                "description": [
                    "The target map to be cleaned."
                ]
            }
        },
        "returns": {
            "description": [
                "Returns a map with null key-value pairs removed."
            ]
        }
    },
    "extend": {
        "description": [
            "Extends a Map with the values of another Map, disregarding null values in the process.",
            ""
        ],
        "parameters": {
            "maps": {
                "description": [
                    "The maps to get extended."
                ]
            }
        },
        "returns": {
            "description": [
                "Returns the merged maps."
            ]
        }
    },
    "diff": {
        "description": [
            "Extracts the differences between two or more maps, comparing the first map against the rest.",
            ""
        ],
        "parameters": {
            "maps": {
                "description": [
                    "A list of maps that will be diffed."
                ]
            }
        },
        "returns": {
            "description": [
                "Returns a map of the unique properties."
            ]
        },
        "example": [
            {
                "description": [
                    "Pull out the unique properties of the second map when compared to the first."
                ],
                "code": [
                    "$map-1: (",
                    "  color: orange,",
                    "  background: black,",
                    ");",
                    "",
                    "$map-2: (",
                    "  color: red,",
                    "  background: black,",
                    ");",
                    "",
                    "$diffed: diff($map-1, $map-2); // returns (color: red);"
                ]
            }
        ]
    },
    "map-keys-prefix": {
        "description": [
            "Prefixes the keys in a map with the specified prefix and separator.",
            ""
        ],
        "parameters": {
            "map": {
                "description": [
                    "The target map."
                ]
            },
            "prefix": {
                "description": [
                    "The string used to prefix all keys in the map."
                ]
            },
            "separator": {
                "description": [
                    "The string used as a separator between the prefix and the key."
                ]
            }
        },
        "returns": {
            "description": [
                "Returns the modified map with all keys prefixed."
            ]
        }
    },
    "to-fixed": {
        "description": [
            "Rounds a number to a certain precision",
            ""
        ],
        "parameters": {
