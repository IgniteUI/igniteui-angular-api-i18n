{
    "pad": {
        "description": [
            "間隔の値を考慮したコンポーネントのサイズに基づく値を返します。",
            "渡されたサイズは、比較する前に絶対値に変換されます。",
            ""
        ],
        "parameters": {
            "sm": {
                "description": [
                    "コンポーネントのサイズが small の場合の優先値。"
                ]
            },
            "md": {
                "description": [
                    "コンポーネントのサイズが medium の場合の優先値。"
                ]
            },
            "lg": {
                "description": [
                    "コンポーネントのサイズが large の場合の優先値。"
                ]
            },
            "dir": {
                "description": [
                    "優先方向 - inline (インライン) または block (ブロック)。"
                ]
            }
        },
        "returns": {
            "description": [
                "評価された値。"
            ]
        },
        "example": [
            {
                "code": [
                    ".my-component {",
                    "  padding: pad(4px, 8px, 16px);",
                    "}"
                ]
            }
        ]
    },
    "pad-inline": {
        "description": [
            "インライン間隔を追加するために使用されます。",
            ""
        ],
        "parameters": {
            "sm": {
                "description": [
                    "コンポーネントのサイズが small の場合の優先値。"
                ]
            },
            "md": {
