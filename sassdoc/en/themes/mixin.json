{
    "css-vars": {
        "description": [
            "Add theme colors as CSS variables to a given scope.",
            ""
        ],
        "parameters": {
            "theme": {
                "description": [
                    "The component theme to be used."
                ]
            },
            "scope": {
                "description": [
                    "The CSS variables scope to be used. (optional)"
                ]
            }
        },
        "example": [
            {
                "description": [
                    "Convert grid theme colors to css variables"
                ],
                "code": [
                    "$my-grid-theme grid-theme(",
                    "  $header-background: red,",
                    "  $content-background: #222",
                    ");",
                    ".my-grid {",
                    "  @include css-vars($my-grid-theme);",
                    "}"
                ]
            }
        ]
    },
    "sizing": {
        "description": [
            "Adds sizing CSS variables to the scope.",
            ""
        ]
    },
    "sizable": {
        "description": [
            "Adds the required CSS properties so that the scope can react to size changes.",
            ""
        ],
        "example": [
            {
                "description": [
                    "Sample usage"
                ],
                "code": [
                    ".my-component {",
                    "  @include sizable();",
                    "}"
                ]
            }
        ]
    },
    "spacing": {
        "description": [
            "Adds spacing CSS variables to the scope.",
            ""
        ]
    }
}