{
    "bem--sep-elem": {
        "example": [
            {
                "description": [
                    "<p>Change the element separator from &#39;__&#39; to &#39;-&#39;</p>",
                    ""
                ],
                "code": [
                    "$bem--sep-elem: '-';",
                    "",
                    "@include b(block) {",
                    "   @include e(element) {",
                    "     background: blue;",
                    "   }",
                    "}",
                    "",
                    "// Generated CSS",
                    ".block-element { background: blue; }"
                ]
            }
        ]
    },
    "bem--sep-mod": {
        "example": [
            {
                "description": [
                    "<p>Change the modifier separator from &#39;--&#39; to &#39;---&#39;</p>",
                    ""
                ],
                "code": [
                    "$bem--sep-mod: '---';",
                    "",
                    "@include b(block) {",
                    "   @include m(modifier) {",
                    "     background: red;",
                    "   }",
                    "}",
                    "",
                    "// Generated CSS",
                    ".block---modifier { background: red; }"
                ]
            }
        ]
    },
    "bem--sep-mod-val": {
        "example": [
            {
                "description": [
                    "<p>Change the modifier value separator from &#39;-&#39; to &#39;_&#39;</p>",
                    ""
                ],
                "code": [
                    "$bem--sep-mod-val: '_';",
                    "",
                    "@include b(block) {",
                    "   @include m(modifier, value) {",
                    "     background: red;",
                    "   }",
                    "}",
                    "",
                    "// Generated CSS",
                    ".block--modifier_value { background: red; }"
                ]
            }
        ]
    }
}