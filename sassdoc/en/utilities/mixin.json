{
    "register-component": {
        "description": [
            "Registers a component to the list of known components.",
            ""
        ],
        "parameters": {
            "name": {
                "description": [
                    "The component name."
                ]
            },
            "deps": {
                "description": [
                    "A list of all components the component depends on."
                ]
            }
        }
    },
    "add-deps": {
        "description": [
            "Adds dependecies to a component's internal usedBy list.",
            ""
        ],
        "parameters": {
            "component": {
                "description": [
                    "The component name."
                ]
            },
            "deps": {
                "description": [
                    "The dependecies to be added to the component's usedBy list."
                ]
            }
        }
    },
    "dependecy-tree": {
        "description": [
            "Modifies the global components register by updating the usedBy list for each component.",
            ""
        ],
        "parameters": {
            "components": {
                "description": [
                    "A map of all registered components."
                ]
            }
        }
    },
    "gen-color-class": {
        "description": [
            "Generates a CSS class name for a color from a",
            "given name, variant, prefix and suffix",
            ""
        ],
        "parameters": {
            "name": {
                "description": [
                    "The main class name."
                ]
            },
            "variant": {
                "description": [
                    "An additional string to be attached to the main class name."
                ]
            },
            "prefix": {
                "description": [
                    "A suffix to be attached to the name and variant string."
                ]
            }
        }
    },
    "gen-color-classes": {
        "description": [
            "Generates CSS class names for all colors from",
            "for a given property and color palette, with",
            "optional prefix and suffix attached to the class name.",
            ""
        ],
        "parameters": {
            "prop": {
                "description": [
                    "The CSS property to assign the palette color to."
                ]
            },
            "prefix": {
                "description": [
                    "A prefix to be attached to the class name."
                ]
            },
            "suffix": {
                "description": [
                    "A suffix to be attached to the class name."
                ]
            },
            "palette": {
                "description": [
                    "The palette to use to generate css class names for."
                ]
            }
        },
        "example": [
            {
                "description": [
                    "Generate background classes with colors from the palette."
                ],
                "code": [
                    "// Will generate class names like",
                    "// .my-primary-500-bg { ... };",
                    "@include gen-color-classes(",
                    "  $prop: 'background-color',",
                    "  $prefix: 'my',",
                    "  $suffix: 'bg'",
                    ");"
                ]
            }
        ]
    },
    "color-classes": {
        "description": [
            "Generates CSS class names for all colors from",
            "for a given property and color palette, with",
            "optional prefix and suffix attached to the class name.",
            ""
        ],
        "parameters": {
            "prop": {
                "description": [
                    "The CSS property to assign the palette color to."
                ]
            },
            "prefix": {
                "description": [
                    "A prefix to be attached to the class name."
                ]
            },
            "suffix": {
                "description": [
                    "A suffix to be attached to the class name."
                ]
            },
            "palette": {
                "description": [
                    "The igx palette to use to generate css class names for."
                ]
            }
        },
        "example": [
            {
                "description": [
                    "Generate background classes with colors from the palette."
                ],
                "code": [
                    "// Will generate class names like",
                    "// .igx-primary-500-bg { ... };",
                    "@include color-classes(",
                    "  $prop: 'background-color',",
                    "  $suffix: 'bg'",
                    ");"
                ]
            }
        ]
    },
    "line-clamp": {
        "description": [
            "Truncates text to a specific number of lines.",
            ""
        ],
        "parameters": {
            "lines": {
                "description": [
                    "The number of lines to show"
                ]
            },
            "inline": {
                "description": [
                    "Sets whether an element displays inline-box or box"
                ]
            },
            "vertical": {
                "description": [
                    "Sets whether an element lays out its contents horizontally or vertically"
                ]
            }
        },
        "example": [
            {
                "description": [
                    "Truncates text after the fourth line"
                ],
                "code": [
                    "@include line-clamp(4, true, true);"
                ]
            }
        ]
    },
    "ellipsis": {
        "description": [
            "Applies text-overflow ellipsis to e text element.",
            "This won't work on display flex elements.",
            ""
        ],
        "example": [
            {
                "code": [
                    ".my-class {",
                    "  @include ellipsis();",
                    "}"
                ]
            }
        ]
    },
    "hide-default": {
        "description": [
            "Hides the element from the DOM.",
            ""
        ],
        "example": [
            {
                "description": [
                    "Sample usage"
                ],
                "code": [
                    "input[type=\"checkbox\"] {",
                    "  @include hide-default();",
                    "}"
                ]
            }
        ]
    }
}