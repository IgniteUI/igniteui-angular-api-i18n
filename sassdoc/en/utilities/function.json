{
    "pad": {
        "description": [
            "Returns a value based on the size of the component taking spacing values into consideration.",
            "The passed sizes are converted to absolute values before comparing.",
            ""
        ],
        "parameters": {
            "sm": {
                "description": [
                    "The preferred value when the component's size is small."
                ]
            },
            "md": {
                "description": [
                    "The preferred value when the component's size is medium."
                ]
            },
            "lg": {
                "description": [
                    "The preferred value when the component's size is large."
                ]
            },
            "dir": {
                "description": [
                    "The preferred direction - inline or block."
                ]
            }
        },
        "returns": {
            "description": [
                "The evaluated value."
            ]
        },
        "example": [
            {
                "code": [
                    ".my-component {",
                    "  padding: pad(4px, 8px, 16px);",
                    "}"
                ]
            }
        ]
    },
    "pad-inline": {
        "description": [
            "Used to add inline spacing.",
            ""
        ],
        "parameters": {
            "sm": {
                "description": [
                    "The preferred value when the component's size is small."
                ]
            },
            "md": {
                "description": [
                    "The preferred value when the component's size is medium."
                ]
            },
            "lg": {
                "description": [
                    "The preferred value when the component's size is large."
                ]
            }
        },
        "returns": {
            "description": [
                "The evaluated value."
            ]
        },
        "example": [
            {
                "code": [
                    ".my-component {",
                    "  padding: pad-inline(4px, 8px, 16px);",
                    "}"
                ]
            }
        ]
    },
    "pad-block": {
        "description": [
            "Used to add block spacing.",
            ""
        ],
        "parameters": {
            "sm": {
                "description": [
                    "The preferred value when the component's size is small."
                ]
            },
            "md": {
                "description": [
                    "The preferred value when the component's size is medium."
                ]
            },
            "lg": {
                "description": [
                    "The preferred value when the component's size is large."
                ]
            }
        },
        "returns": {
            "description": [
