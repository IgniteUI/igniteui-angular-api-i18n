                "description": [
                    "The number to be rounded"
                ]
            },
            "precision": {
                "description": [
                    "Specifies the number of the digits after the decimal separator"
                ]
            }
        },
        "returns": {
            "description": [
                "The rounded number"
            ]
        }
    },
    "to-string": {
        "description": [
            "Converts a number to a string.",
            ""
        ],
        "parameters": {
            "num": {
                "description": [
                    "The number to convert."
                ]
            },
            "radix": {
                "description": [
                    "The base radix to use for the conversion."
                ]
            }
        },
        "returns": {
            "description": [
                "The resulting string."
            ]
        }
    },
    "unitless": {
        "description": [
            "Removes measurement units from variable.",
            ""
        ],
        "parameters": {
            "var": {
                "description": [
                    "The variable to remove the unit of."
                ]
            }
        },
        "returns": {
            "description": [
                "The given variable without units."
            ]
        }
    },
    "is-root": {
        "description": [
            "Returns true if the scope where it's called is the root of the document.",
            ""
        ],
        "returns": {
            "description": [
                "Returns a boolean depending on the scope where it's called"
            ]
        },
        "example": [
            {
                "description": [
                    "Check if the current scope is root"
                ],
                "code": [
                    "@mixin smart-mixin() {",
                    "  $scope: if(is-root(), ':root', '&');",
                    "",
                    "  #{$scope} {",
                    "    /* style rules here */",
                    "  }",
                    "}"
                ]
            }
        ]
    },
    "is-host": {
        "description": [
            "Returns true if the scope where it's called is :host.",
            ""
        ],
        "returns": {
            "description": [
                "Returns a boolean depending on the scope where it's called"
            ]
        },
        "example": [
            {
                "description": [
                    "Check if the current scope is :root"
                ],
                "code": [
                    "@mixin smart-mixin() {",
                    "  $host: is-host();",
                    "",
                    "  @if is-host() {",
                    "    /* style rules here */",
                    "  }",
                    "}"
                ]
            }
        ]
    },
    "split": {
