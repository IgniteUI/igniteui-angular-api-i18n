{
    "palette": {
        "description": [
            "カラー パレットを生成します。",
            ""
        ],
        "parameters": {
            "primary": {
                "description": [
                    "基本パレットの生成に使用する primary カラー (必須)。"
                ]
            },
            "secondary": {
                "description": [
                    "二次色パレットの生成に使用する secondary カラー (必須)。"
                ]
            },
            "surface": {
                "description": [
                    "コンポーネントの背景として使用されるカラー (必須)。"
                ]
            },
            "gray": {
                "description": [
                    "グレースケール パレットの生成に使用するカラー (オプション)。"
                ]
            },
            "info": {
                "description": [
                    "アプリケーション内で使用する information カラー (オプション)。"
                ]
            },
            "success": {
                "description": [
                    "アプリケーション内で使用する success カラー (オプション)。"
                ]
            },
            "warn": {
                "description": [
                    "アプリケーション内で使用する warning カラー (オプション)。"
                ]
            },
            "error": {
                "description": [
                    "アプリケーション内で使用する error カラー (オプション)。"
                ]
            },
            "variant": {
                "description": [
                    "内部で使用されます (オプション)。"
                ]
            }
        },
        "returns": {
            "description": [
                "渡された基本色 (primary、secondary、gray など) の色合いで構成されるマップ。"
            ]
        },
        "example": [
            {
                "code": [
                    "// 必要な色を渡します。",
                    "$my-palette: palette(",
                    "  $primary: rebeccapurple,",
                    "  $secondary: orange,",
                    "  $surface: white,",
                    ");",
                    "",
                    "// 生成されたパレットの色を CSS 変数として含めます。",
                    "@include palette($my-palette);"
                ]
            }
        ]
    },
    "shades": {
        "description": [
            "指定された色の色合いを生成します。",
            ""
        ],
        "parameters": {
            "name": {
                "description": [
                    "カラーの名前。"
                ]
            },
            "color": {
                "description": [
                    "色合いの生成に使用する基本色。"
                ]
            },
            "shades": {
                "description": [
                    "色合いバリアントのリスト。"
                ]
            },
            "surface": {
                "description": [
                    "surface のカラー。gray の色合いを生成する場合に便利です (オプション)。"
                ]
            }
        },
        "returns": {
            "description": [
                "色合いとそれぞれのコントラスト カラーで構成されるマップ。",
                ""
            ]
        },
        "example": [
            {
                "code": [
                    "$color-name: 'accent';",
                    "",
                    "// 生成されたパレットの色を CSS 変数として含みます。",
                    "@include palette(",
                    "  (",
                    "    #{$color-name}: shades($color-name, #a57865, $IColorShades),",
                    "  )",
                    ");"
                ]
            }
        ]
    },
    "shade": {
        "description": [
            "指定されたベース カラーから色合いを生成します。",
            ""
        ],
        "parameters": {
            "name": {
                "description": [
                    "色合いのバリアントを生成するために使用するベース カラー名 (primary、secondary など)。"
                ]
            },
            "color": {
                "description": [
                    "色合いを生成するために使用するカラー値。"
                ]
            },
            "shade": {
                "description": [
                    "色合いのバリアント。."
                ]
            },
            "surface": {
                "description": [
                    "surface のカラー。gray の色合いを生成するときに便利です (オプション)。"
                ]
            }
        },
        "returns": {
            "description": [
                "HSL 値のリストと元のカラー値を含むマップ。"
            ]
        }
    },
    "color": {
        "description": [
            "カラーパレットから色を取得します。",
            ""
        ],
        "parameters": {
            "palette": {
                "description": [
                    "ソースのパレット マップ (オプション)。"
                ]
            },
            "color": {
                "description": [
                    "カラー パレットからターゲット色を取得します。"
                ]
            },
            "variant": {
                "description": [
                    "カラー パレットからのターゲット色の影"
                ]
            },
            "opacity": {
                "description": [
                    "色合いに適用するオプションの不透明度。"
                ]
            }
        },
        "returns": {
            "description": [
                "パレットからの生の色合いまたは CSS 変数参照。",
                ""
            ]
        },
        "example": [
            {
                "description": [
                    "パレットから色を取得する方法"
                ],
                "code": [
                    "// パレットを指定せずに取得する場合",
                    ".my-component-1 {",
                    "   background: color($color: primary, $variant: 200); // var(--ig-primary-200)",
                    " }",
                    "",
                    " // 特定のパレットを使用して取得する場合",
                    ".my-component-2 {",
                    "   background: color($my-palette, primary, 200); // #88c0e5",
                    " }"
                ]
            },
            {
                "description": [
                    "不透明度を指定して色を取得する方法"
                ],
                "code": [
                    ".my-component-1 {",
                    "   background: color($color: primary, $variant: 200, $opacity: 0.5); // hsl(from var(--ig-primary-200) h s l/0.5)",
                    " }",
                    "",
                    " // 特定のパレットを使用して取得する場合",
                    ".my-component-2 {",
                    "   background: color($my-palette, primary, 200, $opacity: 0.5); // rgba(136, 192, 229, 0.5)",
                    " }"
                ]
            }
        ]
    },
    "contrast-color": {
        "description": [
            "カラー レットから指定のカラー バリアントのためコントラストの色を取得します。color 関数と同様に動作します。",
            ""
        ],
        "parameters": {
            "palette": {
                "description": [
                    "ソースのパレット マップ (オプション)。"
                ]
            },
            "color": {
                "description": [
                    "カラー パレットからターゲット色を取得します。"
                ]
            },
            "variant": {
                "description": [
                    "カラー パレットからのターゲット色の影。"
                ]
            },
            "opacity": {
                "description": [
                    "色合いに適用するオプションの不透明度。"
                ]
            }
        },
        "returns": {
            "description": [
                "パレットからの生のコントラスト色合いまたは CSS 変数。",
                ""
            ]
        },
        "example": [
            {
                "description": [
                    "パレットを通さずに"
                ],
                "code": [
                    ".my-component {",
                    "   background: color($color: 'primary', $variant: 200);",
                    "   color: contrast-color($color: 'primary', $variant: 200);",
                    " }"
                ]
            }
        ]
    },
    "chart-brushes": {
        "description": [
            "チャート ブラシとして使用される色のリストを返します。戻り値は、enhanced-accessibility の値によって異なります。",
            ""
        ],
        "returns": {
            "description": [
                "チャート ブラシとして使用される カラーのリスト。"
            ]
        }
    }
}