{
    "register-component": {
        "description": [
            "既知のコンポーネントのリストにコンポーネントを登録します。",
            ""
        ],
        "parameters": {
            "name": {
                "description": [
                    "コンポーネント名。"
                ]
            },
            "deps": {
                "description": [
                    "コンポーネントが依存しているすべてのコンポーネントのリスト。"
                ]
            }
        }
    },
    "add-deps": {
        "description": [
            "コンポーネントの内部 usedBy リストに依存関係を追加します。",
            ""
        ],
        "parameters": {
            "component": {
                "description": [
                    "コンポーネント名。"
                ]
            },
            "deps": {
                "description": [
                    "コンポーネントの usedBy リストに追加する依存関係。"
                ]
            }
        }
    },
    "dependecy-tree": {
        "description": [
            "グローバルなコンポーネント レジスターを更新し、各コンポーネントの usedBy リストを修正します。",
            ""
        ],
        "parameters": {
            "components": {
                "description": [
                    "登録済みすべてのコンポーネントのマップ。"
                ]
            }
        }
    },
    "gen-color-class": {
        "description": [
            "指定した名前、バリアント、プレフィクスと接尾辞で",
            "CSS クラス名を生成します。",
            ""
        ],
        "parameters": {
            "name": {
                "description": [
                    "メイン クラス名"
                ]
            },
            "variant": {
                "description": [
                    "メイン クラス名に連結される追加文字列。"
                ]
            },
            "prefix": {
                "description": [
                    "name と variant 文字列に連結される suffix。"
                ]
            }
        }
    },
    "gen-color-classes": {
        "description": [
            "指定したプロパティとカラー パレットのすべての色の",
            "CSS クラス名を生成します。",
            "オプションでプレフィックスとサフィックスをクラス名に添付します。",
            ""
        ],
        "parameters": {
            "prop": {
                "description": [
                    "色のパレットに割り当てられる CSS プロパティ。"
                ]
            },
            "prefix": {
                "description": [
                    "クラス名に連結するプレフィックス。"
                ]
            },
            "suffix": {
                "description": [
                    "クラス名に連結されるサフィックス。"
                ]
            },
            "palette": {
                "description": [
                    "CSS クラス名の生成に使用するパレット。"
                ]
            }
        },
        "example": [
            {
                "description": [
                    "パレットの色でバックグラウンド クラスを生成します。"
                ],
                "code": [
                    "// 次のようなクラス名を生成します",
                    "// .my-primary-500-bg { ... };",
                    "@include gen-color-classes(",
                    "  $prop: 'background-color',",
                    "  $prefix: 'my',",
                    "  $suffix: 'bg'",
                    ");"
                ]
            }
        ]
    },
    "color-classes": {
        "description": [
            "指定したプロパティとカラー パレットのすべての色",
            "の CSS クラス名を生成します。",
            "オプションでプレフィックスとサフィックスをクラス名に添付します。",
            ""
        ],
        "parameters": {
            "prop": {
                "description": [
                    "パレット カラーに割り当てられる CSS プロパティ。"
                ]
            },
            "prefix": {
                "description": [
                    "クラス名に連結するプレフィックス。"
                ]
            },
            "suffix": {
                "description": [
                    "クラス名に連結されるサフィックス。"
                ]
            },
            "palette": {
                "description": [
                    "CSS クラス名の生成に使用する igx パレット。"
                ]
            }
        },
        "example": [
            {
                "description": [
                    "パレットの色でバックグラウンド クラスを生成します。"
                ],
                "code": [
                    "// 次のようなクラス名を生成します。",
                    "// .igx-primary-500-bg { ... };",
                    "@include color-classes(",
                    "  $prop: 'background-color',",
                    "  $suffix: 'bg'",
                    ");"
                ]
            }
        ]
    },
    "line-clamp": {
        "description": [
            "特定の行数でテキストを切り捨てます。",
            ""
        ],
        "parameters": {
            "lines": {
                "description": [
                    "表示する行数。"
                ]
            },
            "inline": {
                "description": [
                    "要素が inline-box または box を表示するかどうかを設定します。"
                ]
            },
            "vertical": {
                "description": [
                    "要素がコンテンツを水平または垂直に配置するかどうかを設定します。"
                ]
            }
        },
        "example": [
            {
                "description": [
                    "4 行目以降のテキストを切り捨てます。"
                ],
                "code": [
                    "@include line-clamp(4, true, true);"
                ]
            }
        ]
    },
    "ellipsis": {
        "description": [
            "E テキスト要素に text-overflow 省略記号を適用します。",
            "この処理は display flex の要素には機能しません。",
            ""
        ],
        "example": [
            {
                "code": [
                    ".my-class {",
                    "  @include ellipsis();",
                    "}"
                ]
            }
        ]
    },
    "hide-default": {
        "description": [
            "DOM から要素を非表示にします。",
            ""
        ],
        "example": [
            {
                "description": [
                    "例"
                ],
                "code": [
                    "input[type=\"checkbox\"] {",
                    "  @include hide-default();",
                    "}"
                ]
            }
        ]
    }
}