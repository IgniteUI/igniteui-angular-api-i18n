{
    "em": {
        "description": [
            "ピクセルを相対値 (em) に変換します。",
            ""
        ],
        "parameters": {
            "pixels": {
                "description": [
                    "変換するピクセル値。"
                ]
            },
            "context": {
                "description": [
                    "対して変換するベース コンテキスト。"
                ]
            }
        },
        "returns": {
            "description": [
                "em に変換されたピクセル値を返します。"
            ]
        },
        "example": [
            {
                "code": [
                    ".my-component {",
                    "  margin: em(10px) em(5px);",
                    "}",
                    "",
                    "// 出力",
                    ".my-component {",
                    "  margin: 0.625em 0.3125em;",
                    "}"
                ]
            }
        ]
    },
    "rem": {
        "description": [
            "ピクセルをルート相対値 (rem) に変換します。",
            ""
        ],
        "parameters": {
            "pixels": {
                "description": [
                    "変換するピクセル値。"
                ]
            },
            "context": {
                "description": [
                    "対して変換するベース コンテキスト。"
                ]
            }
        },
        "returns": {
            "description": [
                "rem に変換されたピクセル値を返します。"
            ]
        },
        "example": [
            {
                "code": [
                    ".my-component {",
                    "  margin: rem(10px) rem(5px);",
                    "}",
                    "",
                    "// 出力",
                    ".my-component {",
                    "  margin: 0.625rem 0.3125rem;",
                    "}"
                ]
            }
        ]
    },
    "px": {
        "description": [
            "相対値 (em/rem) をピクセルに変換します。",
            ""
        ],
        "parameters": {
            "num": {
                "description": [
                    "変換される相対値。"
                ]
            },
            "context": {
                "description": [
                    "対して変換するベース コンテキスト。"
                ]
            }
        },
        "returns": {
            "description": [
                "ピクセルに変換された相対値を返します。"
            ]
        },
        "example": [
            {
                "code": [
                    ".my-component {",
                    "  margin: px(3rem);",
                    "}",
                    "",
                    "// 出力",
                    ".my-component {",
                    "  margin: 48px;",
                    "}"
                ]
            }
        ]
    },
    "type-style": {
        "description": [
            "ITypeScale リストに準拠するタイプ スタイルを含むタイプ スケール マップを作成します。",
            ""
        ],
        "parameters": {
            "font-family": {
                "description": [
                    "タイプ スタイルのフォント ファミリ。"
                ]
            },
            "font-size": {
                "description": [
                    "タイプ スタイルのフォントのサイズ。"
                ]
            },
            "font-weight": {
                "description": [
                    "タイプ スタイルのフォントのウェイト。"
                ]
            },
            "font-style": {
                "description": [
                    "タイプ スタイルのフォント スタイル。"
                ]
            },
            "line-height": {
                "description": [
                    "タイプ スタイルの線の高さ。"
                ]
            },
            "letter-spacing": {
                "description": [
                    "タイプ スタイルの文字の間隔。"
                ]
            },
            "text-transform": {
                "description": [
                    "タイプ スタイルの text-transform プロパティ。"
                ]
            },
            "margin-top": {
                "description": [
                    "タイプ スタイルの margin-top プロパティ。"
                ]
            },
            "margin-bottom": {
                "description": [
                    "タイプ スタイルの margin-bottom プロパティ。"
                ]
            }
        },
        "returns": {
            "description": [
                "タイプ スタイルのすべての定義済みのプロパティのマップ。"
            ]
        },
        "example": [
            {
                "code": [
                    "$main_navigation: type-style(",
                    "   $font-size: rem(14px),",
                    "   $font-weight: 600,",
                    "   $letter-spacing: rem(.1px),",
                    "   $line-height: rem(14px),",
                    "   $text-transform: none,",
                    ");",
                    "",
                    "// type-style() mixin を使用して、type-style() 関数から生成された新しいタイプ スタイルを使用します。",
                    ".main-nav {",
                    "  @include type-style($main_navigation);",
                    "}"
                ]
            }
        ]
    },
