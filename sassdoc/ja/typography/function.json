        "returns": {
            "description": [
                "すべての定義済み タイプ スケールのマップ。"
            ]
        },
        "example": [
            {
                "code": [
                    "// 最初に使用するタイプ スタイルを定義します",
                    "$my-body-1: type-style(",
                    "   $font-size: rem(14px),",
                    ");",
                    "",
                    "// タイプ スタイル マップを使用して、既存のマップの 1 つをオーバーライドします。",
                    "$type-scale: type-scale(",
                    "  ...",
                    "  $body-1: $my-body-1,",
                    "  ...",
                    ");"
                ]
            }
        ]
    },
    "type-scale-category": {
        "description": [
            "タイプ スケール カテゴリ config を取得します。",
            ""
        ],
        "parameters": {
            "scale": {
                "description": [
                    "type-scale が生成されるようにタイプ スケールのマップ参照。"
                ]
            },
            "category": {
                "description": [
                    "設定する必要のあるスケール カテゴリ。'h1' など。"
                ]
            }
        },
        "returns": {
            "description": [
                "タイプ スケールでの選択されたカテゴリの config マップ。"
            ]
        },
        "example": [
            {
                "description": [
                    "`h1` scale のための scale カテゴリ config の型を取得します。"
                ],
                "code": [
                    "$h1-type-scale: type-scale-category($type-scale, 'h1');"
                ]
            }
        ]
    },
    "_normalize-font-family": {
        "description": [
            "CSS カスタム プロパティで使用するために、font-family の値を正規化します。",
            "値が Sass 文字列の場合、引用符が解除されて生の CSS トークンが生成され、",
            "\"'Comic Sans MS'、sans-serif\" のような文字列化された",
            "フォント リストが正しく出力されます。",
            "その他のすべてのタイプ (リスト、var() 式、inherit などのキーワードなど) はそのまま返されます。",
            ""
        ],
        "parameters": {
            "value": {
                "description": [
                    "正規化する font-family の値です。"
                ]
            }
        },
        "returns": {
            "description": [
                "正規化された値です。"
            ]
        }
    }
