{
    "bem-selector": {
        "description": [
            "<p>完全 BEM セレクターを生成します。</p>",
            ""
        ],
        "parameters": {
            "block": {
                "description": [
                    "<p>文字列ブロックの名前。必須。</p>",
                    ""
                ]
            },
            "elem": {
                "description": [
                    "<p>サブ要素の名前。<code>$mod</code> が存在しない場合は、",
                    "$block と結合されます。$mod が存在する場合、それは <code>$block--$mod</code> の下にネストされます。</p>",
                    ""
                ]
            },
            "mod": {
                "description": [
                    "<p>ブロック修飾。</p>",
                    ""
                ]
            },
            "mods": {
                "description": [
                    "<p>ブロック修飾のリスト。</p>",
                    ""
                ]
            }
        },
        "returns": {
            "description": [
                "<p>生成された BEM セレクター文字列。</p>",
                ""
            ]
        },
        "example": [
            {
                "description": [
                    "<p>ブロックを含みます。</p>",
                    ""
                ],
                "code": [
                    "$selector: bem-selector(block); // returns .block"
                ]
            },
            {
                "description": [
                    "<p>要素とブロックを含みます。</p>",
                    ""
                ],
                "code": [
                    "$selector: bem-selector(block, $elem: elem); // returns .block__elem"
                ]
            },
            {
                "description": [
                    "<p>ブロック、要素と要素修飾を含みます。</p>",
                    ""
                ],
                "code": [
                    "$selector: bem-selector(block, $elem: (elem, mod); // returns .block__elem--mod"
                ]
            },
            {
                "description": [
                    "<p>ブロックとブロック修飾を含みます。</p>",
                    ""
                ],
                "code": [
                    "$selector: bem-selector(block, $mod: mod) // returns .block--mod"
                ]
            },
            {
                "description": [
                    "<p>ブロックおよび複数のブロック修飾子を含みます。</p>",
                    ""
                ],
                "code": [
                    "$selector: bem-selector(block, $mods: (mod-1, mod-2)) // returns .block--mod-1.block--mod-2"
                ]
            },
            {
                "description": [
                    "<p>ブロック修飾を続くブロック サブ要素を含みます。</p>",
                    ""
                ],
                "code": [
                    "$selector: bem-selector(block, $m: mod, $e: elem); // returns .block--mod .block__elem"
                ]
            }
        ]
    },
    "elem": {
        "description": [
            "<p>BEM 要素セレクター文字列を返します。修飾子が指定されている場合は、要素セレクターに追加されます。</p>",
            ""
        ],
        "parameters": {
            "block": {
                "description": [
                    "<p>ブロックの名前。</p>",
                    ""
                ]
            },
            "elem": {
                "description": [
                    "<p>要素の名前。</p>",
                    ""
                ]
            },
            "mod": {
                "description": [
                    "<p>修飾の名前。オプション。</p>",
                    ""
                ]
            }
        },
        "returns": {
            "description": [
                "<p>BEM 要素セレクター文字列。</p>",
                ""
            ]
        },
        "example": [
            {
                "code": [
                    "$selector: elem('button', 'icon') // returns '.button__icon'",
                    "$selector: elem('button', 'icon', 'big') // returns '.button__icon--big'"
                ]
            }
        ]
    },
    "mod": {
        "description": [
            "<p>ブロックの BEM 修飾子セレクター文字列を返します。</p>",
            ""
        ],
        "parameters": {
            "block": {
                "description": [
                    "<p>ブロックの名前。</p>",
                    ""
                ]
            },
            "mod": {
                "description": [
                    "<p>修飾の名前。</p>",
                    ""
                ]
            }
        },
        "returns": {
            "description": [
                "<p>BEM 修飾子セレクター文字列。</p>",
                ""
            ]
        },
        "example": [
            {
                "code": [
                    "$selector: mod('button', 'primary') // returns '.button--primary'",
                    "$selector: mod('card', 'outlined') // returns '.card--outlined'"
                ]
            }
        ]
    }
}