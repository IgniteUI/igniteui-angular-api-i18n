{
    "css-vars": {
        "description": [
            "テーマの色を CSS 変数として特定のスコープに追加します。",
            ""
        ],
        "parameters": {
            "theme": {
                "description": [
                    "使用するコンポーネントのテーマ。"
                ]
            },
            "scope": {
                "description": [
                    "使用する CSS 変数のスコープ。(オプション)"
                ]
            }
        },
        "example": [
            {
                "description": [
                    "グリッド テーマの色を CSS 変数に変換します。"
                ],
                "code": [
                    "$my-grid-theme grid-theme(",
                    "  $header-background: red,",
                    "  $content-background: #222",
                    ");",
                    ".my-grid {",
                    "  @include css-vars($my-grid-theme);",
                    "}"
                ]
            }
        ]
    },
    "sizable": {
        "description": [
            "スコープがサイズの変更に対応できるように、必要な CSS プロパティを追加します。",
            ""
        ],
        "example": [
            {
                "description": [
                    "例"
                ],
                "code": [
                    ".my-component {",
                    "  @include sizable();",
                    "}"
                ]
            }
        ]
    },
    "spacing": {
        "description": [
            "スコープにスペース CSS 変数を追加します。",
            ""
        ]
    }
}