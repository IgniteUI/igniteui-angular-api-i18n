    "theme": {
        "description": [
            "Generates an Ignite UI for Angular global theme.",
            ""
        ],
        "parameters": {
            "palette": {
                "description": [
                    "An palette to be used by the global theme."
                ]
            },
            "schema": {
                "description": [
                    "The schema used as basis for styling the components."
                ]
            },
            "exclude": {
                "description": [
                    "A list of igx components to be excluded from the global theme styles."
                ]
            },
            "roundness": {
                "description": [
                    "Sets the global roundness factor (the value can be any decimal fraction between 0 and 1) for all components."
                ]
            },
            "elevation": {
                "description": [
                    "Turns on/off elevations for all components in the theme."
                ]
            },
            "elevations": {
                "description": [
                    "The elevation map to be used by all component themes."
                ]
            }
        }
    },
