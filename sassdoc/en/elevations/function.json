{
    "_is-shadow": {
        "description": [
            "Checks if the passed argument is a valid box-shadow.",
            ""
        ],
        "parameters": {
            "shadow": {
                "description": [
                    "A list of shadow properties."
                ]
            }
        },
        "returns": {
            "description": [
                "Returns a boolean depending on if the passed argument is a valid shadow."
            ]
        }
    },
    "_transform-shadow": {
        "description": [
            "Transforms the passed box-shadow list according to the elevation factor value.",
            ""
        ],
        "parameters": {
            "shadow": {
                "description": [
                    "A list of shadow properties."
                ]
            }
        },
        "returns": {
            "description": [
                "The transformed shadow list."
            ]
        }
    },
    "box-shadow": {
        "description": [
            "Sorts out a list of valid only box-shadows.",
            ""
        ],
        "parameters": {
            "shadows": {
                "description": [
                    "A list of shadow values."
                ]
            }
        },
        "returns": {
            "description": [
                "The transformed shadow list."
            ]
        },
        "example": [
            {
                "code": [
                    ".my-component {",
                    "  box-shadow: box-shadow((0 0 2px 3px black, 0 6px 9px orange));",
                    "}",
                    "",
                    "// Output",
                    ".my-component {",
                    "  box-shadow:",
                    "      0 0 calc(--ig-elevation-factor * 2px) calc(--ig-elevation-factor * 3px) black,",
                    "      0 calc(--ig-elevation-factor * 6px) calc(--ig-elevation-factor * 9px) orange;",
                    "}"
                ]
            }
        ]
    },
    "elevation": {
        "description": [
            "Gets a CSS elevation variable by name.",
            ""
        ],
        "parameters": {
            "name": {
                "description": [
                    "The name of the shadow."
                ]
            }
        },
        "returns": {
            "description": [
                "The CSS elevation variable"
            ]
        },
        "example": [
            {
                "code": [
                    ".my-component {",
                    "  box-shadow: elevation(5); // var(--ig-elevation-5)",
                    "}"
                ]
            }
        ]
    }
}