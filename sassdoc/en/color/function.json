{
    "adaptive-contrast": {
        "description": [
            "<p>Returns a CSS runtime calculated relative color(black or white) for a given color.</p>",
            ""
        ],
        "parameters": {
            "color": {
                "description": [
                    "<p>The base color used in the calculation.</p>",
                    ""
                ]
            }
        },
        "returns": {
            "description": [
                "<p>Returns a relative HSL color where the lightness is adjusted",
                "based on the specified contrast level, resulting in either black or white.</p>",
                ""
            ]
        },
        "example": [
            {
                "code": [
                    ".my-component {",
                    "   --bg: #09f;",
                    "   background: var(--bg);",
                    "   color: adaptive-contrast(var(--bg)); // hsl(from color(from var(--bg) var(--y-contrast)) h 0 l)",
                    " }"
                ]
            }
        ]
    },
    "text-contrast": {
        "description": [
            "<p>Returns a contrast color for a passed color.</p>",
            ""
        ],
        "parameters": {
            "background": {
                "description": [
                    "<p>The background color used to return a contrast/forground color for.</p>",
                    ""
                ]
            },
            "foreground": {
                "description": [
                    "<p>A list of foreground colors",
                    "that can be used with the provided background.</p>",
                    ""
                ]
            },
            "contrast": {
                "description": [
                    "<p>The contrast level according to WCAG 2.0 standards.</p>",
                    ""
                ]
            }
        },
        "returns": {
            "description": [
                "<p>Returns either white, black, or the provided foreground",
                "color if it meets the required contrast level.</p>",
                ""
            ]
        },
        "example": [
            {
                "code": [
                    ".my-component {",
                    "   background: #09f;",
                    "   color: text-contrast(#09f);",
                    " }"
                ]
            }
        ]
    },
    "to-hsl": {
        "description": [
            "<p>Retruns a comma separated list of hue, saturation, and lightness values for a given color.</p>",
            ""
        ],
        "parameters": {
            "color": {
                "description": [
                    "<p>The color to be converted to an HSL list of values.</p>",
                    ""
                ]
            }
        },
        "returns": {
            "description": [
                "<p>This list of HSL values.</p>",
                ""
            ]
        },
        "example": [
            {
                "description": [
                    "<p>Turn #000 into an HSL list of values</p>",
                    ""
                ],
                "code": [
                    "$hsl-list: to-hsl(#000); // (0deg, 0%, 0%);"
                ]
            }
        ]
    },
    "contrast": {
        "description": [
            "<p>Calculates the contrast ratio between two colors.</p>",
            ""
        ],
        "parameters": {
            "background": {
                "description": [
                    "<p>The background color.</p>",
                    ""
                ]
            },
            "foreground": {
                "description": [
                    "<p>The foreground color.</p>",
                    ""
                ]
            }
        },
        "returns": {
            "description": [
                "<p>The contrast ratio between the background and foreground colors.</p>",
                ""
            ]
        },
        "example": [
            {
                "code": [
                    "$conrast: contrast(#09f, #000); // 7"
                ]
            }
        ]
    },
    "luminance": {
        "description": [
            "<p>Calculates the luminance for a given color.</p>",
            ""
        ],
        "parameters": {
            "color": {
                "description": [
                    "<p>The color to calculate luminance for.</p>",
                    ""
                ]
            }
        },
        "returns": {
            "description": [
                "<p>The calculated luminance of a given color</p>",
                ""
            ]
        },
        "example": [
            {
                "code": [
                    "$white: luminance(#fff); // 1",
                    "$blue: luminance(#09f); // 0.3",
                    "$black: luminance(#000); // 0"
                ]
            }
        ]
    }
}