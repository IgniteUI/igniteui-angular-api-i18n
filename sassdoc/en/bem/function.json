{
    "elem": {
        "description": [
            "<p>Returns a BEM element selector string. If a modifier is provided, it will be appended to the element selector.</p>",
            ""
        ],
        "parameters": {
            "block": {
                "description": [
                    "<p>The block name.</p>",
                    ""
                ]
            },
            "elem": {
                "description": [
                    "<p>The element name.</p>",
                    ""
                ]
            },
            "mod": {
                "description": [
                    "<p>Optional. The modifier name.</p>",
                    ""
                ]
            }
        },
        "returns": {
            "description": [
                "<p>The BEM element selector string.</p>",
                ""
            ]
        },
        "example": [
            {
                "code": [
                    "elem('button', 'icon')        // returns '.button__icon'",
                    "elem('button', 'icon', 'big') // returns '.button__icon--big'"
                ]
            }
        ]
    },
    "mod": {
        "description": [
            "<p>Returns a BEM modifier selector string for a block.</p>",
            ""
        ],
        "parameters": {
            "block": {
                "description": [
                    "<p>The block name.</p>",
                    ""
                ]
            },
            "mod": {
                "description": [
                    "<p>The modifier name.</p>",
                    ""
                ]
            }
        },
        "returns": {
            "description": [
                "<p>The BEM modifier selector string.</p>",
                ""
            ]
        },
        "example": [
            {
                "code": [
                    "mod('button', 'primary') // returns '.button--primary'",
                    "mod('card', 'outlined') // returns '.card--outlined'"
                ]
            }
        ]
    }
}